# Cloudflare Pages 部署环境变量
# 复制此文件为 .env.cloudflare 并填写实际值

# Cloudflare API Token
# 获取方式: https://dash.cloudflare.com/profile/api-tokens
# 需要权限: Account:Cloudflare Pages:Edit
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare Account ID
# 获取方式: 在 Cloudflare Dashboard 右上角点击你的头像 -> 'My Profile' -> 'API Tokens' 页面
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# 项目名称 (可选，默认使用 ai-converter-system)
PROJECT_NAME=ai-converter-system

# 部署分支 (可选，默认使用 main)
DEPLOY_BRANCH=main

# 构建命令 (可选)
BUILD_COMMAND=npm run build

# Node.js 版本 (可选)
NODE_VERSION=18

# 前端 API 地址 (生产环境)
VITE_API_URL=https://your-backend-api.com

# 自定义域名 (可选)
CUSTOM_DOMAIN=converter.yourdomain.com